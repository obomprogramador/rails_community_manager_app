%div{ style: "display:flex; flex-direction: column; gap: 50px;" }
  %div{ style: "display:flex; flex-direction: column; gap: 10px; padding-top: 150px; margin-top: -20px; padding-bottom: 10px; background-color: #f5f5f5; position: fixed; z-index: 800; width: 600px; box-shadow: 0 4px 6px -4px rgba(0, 0, 0, 0.1);" }
    %h1 Nova Comunidades

    = form_with url: communities_path,
                data: {controller: "community-form", turbo_frame: "_top"} do |f|
      .form-group
        = f.text_field :name, placeholder: "Nome da comunidade",
                      data: {community_form_target: "name"}
      .form-group
        = f.text_area :description, placeholder: "Descrição",
                      data: {community_form_target: "description"}
      = f.submit "Criar Comunidade", class: "btn btn--primary"

  %turbo-frame#community_form_error

  %div{ style: "display:flex; flex-direction: column; margin-top: 400px;" }
    %ul#communities_list{data: {controller: "communities-list"}}
      - @communities.each do |community|
        = render "community", community: community, member_community_ids: @member_community_ids