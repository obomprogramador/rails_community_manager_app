%li.community-card{id: "community_#{community.id}"}
  %h3= community.name
  %p= community.description

  .message-actions
    - if session[:user_id].present?
      - if member_community_ids.include?(community.id)
        = button_tag "Já inscrito",
          type: "button",
          class: "btn btn--sm btn--disabled",
          disabled: true
      - else
        = button_to "Juntar-se",
          community_community_members_path(community.id),
          method: :post,
          params: { user_id: session[:user_id] },
          class: "btn btn--sm btn--primary"
    
    = link_to "Ver mensagens", community_messages_path(community.id), class: "btn btn--sm"

    %span
      = "#{community.total_messages} Mensagens totais."