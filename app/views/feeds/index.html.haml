%h1 Últimas mensagens

.feed-layout{ style: "display:flex; gap:24px; align-items:flex-start;" }
  %section{ style: "flex:1;" }
    - if @messages.any?
      %ul#feed_messages_list
        - @messages.each do |message|
          %li.message-item{ id: "feed_message_#{message.id}" }
            .message-header
              %strong= message.user&.username || "Usuário"
              - if message.community.present?
                %span= " em #{message.community.name}"
              %time= l(message.created_at, format: :short)

            %p.message-content= message.content

            .message-actions
              = link_to "Ver discussão", replies_community_message_path(message.community_id, message.id), class: "btn btn--xs"
    - else
      %p Seu feed ainda está vazio.
      %p Entre em uma comunidade e publique para começar.