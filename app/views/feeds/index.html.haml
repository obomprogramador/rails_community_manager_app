%h1 Feed

.feed-layout{ style: "display:flex; gap:24px; align-items:flex-start;" }
  %aside{ style: "min-width:280px;" }
    %h2 Suas comunidades
    - if @communities.any?
      %ul
        - @communities.each do |community|
          %li
            = link_to community.name, community_messages_path(community.id), class: "btn btn--sm"
    - else
      %p Você ainda não participa de comunidades.
      = link_to "Explorar comunidades", communities_path, class: "btn btn--primary"

  %section{ style: "flex:1;" }
    .feed-header{ style: "display:flex; justify-content:space-between; align-items:center;" }
      %h2 Últimas mensagens
      = link_to "Ver comunidades", communities_path, class: "btn btn--sm"

    - if @messages.any?
      %ul#feed_messages_list
        - @messages.each do |message|
          %li.message-item{ id: "feed_message_#{message.id}" }
            .message-header
              %strong= message.user&.username || "Usuário"
              - if message.community.present?
                %span= " em #{message.community.name}"
              %time= l(message.created_at, format: :short)

            %p.message-content= message.content

            .message-actions
              = link_to "Ver discussão", replies_community_message_path(message.community_id, message.id), class: "btn btn--xs"
    - else
      %p Seu feed ainda está vazio.
      %p Entre em uma comunidade e publique para começar.