%html
  %head
    %title= content_for(:title) || "Community Manager"
    %meta{name: "viewport", content: "width=device-width,initial-scale=1"}
    %meta{name: "apple-mobile-web-app-capable", content: "yes"}
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head
    %link{rel: "manifest", href: "/manifest.json"}
    %link{rel: "icon", href: "/icon.png", type: "image/png"}
    %link{rel: "icon", href: "/icon.png", type: "image/svg+xml"}
    %link{rel: "apple-touch-icon", href: "/icon.png"}
    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    = javascript_importmap_tags
  %body
    = render "layouts/flash"
    - hide_nav = (controller_name == "sessions" && action_name == "new") || (controller_name == "users" && action_name == "new")
    - if session[:user_id].present? && !hide_nav
      %nav{ style: "display:flex; gap:12px; margin-bottom:16px;" }
        = link_to "Feed", feed_path
        = link_to "Comunidades", communities_path
        = button_to "Sair", session_path, method: :delete
    = yield
